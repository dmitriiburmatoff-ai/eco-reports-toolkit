# Игнорировать все файлы Excel (.xls) и Word (.docx)
*.xls
*.xlsx
*.docx
*.doc

# Временные/автосохранённые копии
~$*.docx
~$*.xlsx
~$*.xls
~$*.doc
*.tmp

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.dll
*.dylib

# Виртуальное окружение
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# Файлы IDE
.idea/
.vscode/
*.swp
*.swo

# Выходные папки (результаты работы скриптов)
output/
temp/
logs/
*.log

# Конфигурационные файлы с секретами (если используются)
.env
.env.local
.env.*.local

# Файлы отчётов, которые генерируются и не должны быть в репозитории
# (например, если вы сохраняете результаты прямо в папку со скриптами)
*_отчёт.docx
*_таблица.xlsx
Результат_*.docx
Отчёт_*.docx
Анализ_шума_*.docx
НДВ_*.docx
НМУ_*.docx

# Если вы используете Jupyter Notebooks (но они редко в таких проектах)
*.ipynb_checkpoints/